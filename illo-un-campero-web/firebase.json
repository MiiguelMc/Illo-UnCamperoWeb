{
  "hosting": {
    "public": "dist/illo-un-campero-web/browser",
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/restaurantes",
        "type": 301
      },
      {
        "source": "/index.html",
        "destination": "/restaurantes",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|webp|avif|png|jpg|jpeg|gif|svg|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(html|xml|txt|webmanifest)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "/@(restaurantes|carta|contacto|aviso-legal|privacidad)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "X-XSS-Protection", "value": "1; mode=block" }
        ]
      }
    ]
  }
}
